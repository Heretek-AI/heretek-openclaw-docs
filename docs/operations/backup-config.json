{
  "version": "2.0.0",
  "description": "Automated backup configuration for Heretek OpenClaw",
  "systemd": {
    "timer_unit": "systemd/openclaw-backup.timer",
    "service_unit": "systemd/openclaw-backup.service",
    "environment_file": "/etc/openclaw/backup.env",
    "installation": {
      "copy_units": [
        "sudo cp systemd/openclaw-backup.timer /etc/systemd/system/",
        "sudo cp systemd/openclaw-backup.service /etc/systemd/system/",
        "sudo systemctl daemon-reload",
        "sudo systemctl enable openclaw-backup.timer",
        "sudo systemctl start openclaw-backup.timer"
      ]
    }
  },
  "backup_settings": {
    "base_directory": "/root/.openclaw/backups",
    "temp_directory": "/tmp/openclaw-backup",
    "compression": "gzip",
    "encryption": {
      "enabled": false,
      "algorithm": "aes-256-cbc",
      "key_file": ""
    }
  },
  "schedules": {
    "incremental": {
      "enabled": true,
      "systemd_timer": "openclaw-backup.timer",
      "onCalendar": "*-*-* 02:00:00",
      "description": "Daily incremental backup at 2 AM",
      "retention_days": 30,
      "min_backups": 7,
      "backup_types": ["postgresql", "redis", "workspace", "agent_state", "config"]
    },
    "full": {
      "enabled": true,
      "systemd_timer": "openclaw-backup.timer",
      "onCalendar": "Sun *-*-* 03:00:00",
      "description": "Weekly full backup on Sunday at 3 AM",
      "retention_days": 90,
      "min_backups": 4,
      "backup_types": ["postgresql", "redis", "workspace", "agent_state", "config"]
    }
  },
  "sources": {
    "postgresql": {
      "type": "database",
      "host": "localhost",
      "port": 5432,
      "database": "heretek",
      "user": "heretek",
      "password_env": "POSTGRES_PASSWORD",
      "tables": ["*"],
      "exclude_tables": [],
      "schema_only": false
    },
    "redis": {
      "type": "keyvalue",
      "host": "localhost",
      "port": 6379,
      "password_env": "REDIS_PASSWORD",
      "databases": [0],
      "keys_pattern": "*",
      "format": "rdb"
    },
    "workspace": {
      "type": "filesystem",
      "paths": [
        "/root/.openclaw/workspace",
        "/root/.openclaw/agents",
        "/root/.openclaw/skills",
        "/root/.openclaw/memory"
      ],
      "exclude_patterns": [
        "*.log",
        "*.tmp",
        "node_modules",
        ".git",
        "__pycache__",
        "*.pyc"
      ]
    },
    "agent_state": {
      "type": "filesystem",
      "paths": [
        "/root/.openclaw/agents/*/sessions",
        "/root/.openclaw/agents/*/state",
        "/root/.openclaw/cron"
      ],
      "exclude_patterns": [
        "*.log",
        "*.tmp"
      ]
    },
    "config": {
      "type": "filesystem",
      "paths": [
        "/root/.openclaw/openclaw.json",
        "/root/.openclaw/config.json",
        "/root/heretek/heretek-openclaw/openclaw.json"
      ],
      "exclude_patterns": []
    }
  },
  "rotation": {
    "strategy": "fifo",
    "check_on_backup": true,
    "delete_expired": true,
    "log_deletions": true
  },
  "notifications": {
    "on_success": false,
    "on_failure": true,
    "on_rotation": false,
    "channels": ["file", "console", "email"],
    "email": {
      "enabled": false,
      "on_failure": true,
      "recipients": [],
      "smtp": {
        "host": "",
        "port": 587,
        "user": "",
        "use_tls": true
      }
    }
  },
  "remote_storage": {
    "enabled": false,
    "type": "",
    "s3": {
      "bucket": "",
      "region": "",
      "prefix": "openclaw-backups",
      "encryption": true
    },
    "scp": {
      "host": "",
      "user": "",
      "path": "",
      "ssh_key": ""
    }
  },
  "verification": {
    "verify_after_backup": true,
    "test_restore_monthly": true,
    "checksum_algorithm": "sha256"
  }
}
